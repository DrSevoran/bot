# === Основні налаштування ===
EXCHANGE=mexc
API_KEY=your_mexc_api_key
API_SECRET=your_mexc_api_secret
# API_PASSPHRASE=  # MEXC не вимагає passphrase (на відміну від OKX/KuCoin)

# === Торгові параметри ===
TRADE_PAIR=BTC/USDT
TIMEFRAME=15m
STRATEGY=macd
POSITION_SIZE_USDT=100
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# === Обмеження ===
MAX_OPEN_TRADES=3
MAX_DAILY_TRADES=20
TRAILING_STOP=false
BOTH_SIDES=false

# === Режим ===
DRY_RUN=true
PORT=3000
LOG_LEVEL=info
